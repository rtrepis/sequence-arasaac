  "news.logo-menu.content": [
    {
      "type": 0,
      "value": "¿Sabías que el logo de SequenciAAC es un botón? Haz clic en él para desplegar el menú de navegación principal, desde donde puedes acceder a todas las páginas y funciones de la aplicación."
    }
  ],
  "news.logo-menu.step1.alt": [
    {
      "type": 0,
      "value": "Sección de navegación del menú con los accesos Inicio, Novedades, Edita y Previsualiza"
    }
  ],
  "news.logo-menu.step1.description": [
    {
      "type": 0,
      "value": "La primera sección del menú contiene los accesos directos a todas las páginas: Inicio, Novedades (donde encontrarás todas las actualizaciones), Edita (para crear tus secuencias) y Previsualiza (para verlas e imprimirlas)."
    }
  ],
  "news.logo-menu.step2.alt": [
    {
      "type": 0,
      "value": "Sección de archivos del menú con las opciones Descarga y Carga"
    }
  ],
  "news.logo-menu.step2.description": [
    {
      "type": 0,
      "value": "Desde aquí puedes gestionar los archivos de tus secuencias: Descarga guarda la secuencia actual en un archivo en tu dispositivo, y Carga recupera una secuencia que habías guardado anteriormente."
    }
  ],
  "news.logo-menu.step3.alt": [
    {
      "type": 0,
      "value": "Sección de configuración y selector de idioma"
    }
  ],
  "news.logo-menu.step3.description": [
    {
      "type": 0,
      "value": "Configuración abre el diálogo de configuración por defecto de los pictogramas, donde puedes ajustar tipografía, marcos, posición del texto y otras opciones visuales. Debajo encontrarás el selector de idioma para cambiar entre catalán (ca), castellano (es), inglés (en), francés (fr) o italiano (it)."
    }
  ],
  "news.logo-menu.summary": [
    {
      "type": 0,
      "value": "Haz clic en el logo para abrir el menú principal y acceder a todas las funciones de la app."
    }
  ],
  "news.logo-menu.title": [
    {
      "type": 0,
      "value": "El menú de navegación"
    }
  ],
  "news.moreInfo.button": [
    {
      "type": 0,
      "value": "Más info"
    }
  ],
  "news.multiple-sequences.content": [
    {
      "type": 0,
      "value": "¡Crea tantas secuencias como necesites! Utiliza las pestañas para añadir nuevas secuencias o eliminar las que ya no necesitas. Cada secuencia es independiente y puedes cambiar entre ellas fácilmente."
    }
  ],
  "news.multiple-sequences.img1.alt": [
    {
      "type": 0,
      "value": "Pestañas de secuencia"
    }
  ],
  "news.multiple-sequences.img2.alt": [
    {
      "type": 0,
      "value": "Añadir y eliminar secuencias"
    }
  ],
  "news.multiple-sequences.step1.alt": [
    {
      "type": 0,
      "value": "Secuencia 1 con pictogramas y botón para añadir nueva secuencia"
    }
  ],
  "news.multiple-sequences.step1.description": [
    {
      "type": 0,
      "value": "En la página de edición, busca palabras en el buscador (separadas por comas) y los pictogramas aparecerán automáticamente en la secuencia activa. Haz clic en el botón + para crear una nueva secuencia."
    }
  ],
  "news.multiple-sequences.step2.alt": [
    {
      "type": 0,
      "value": "Dos pestañas de secuencia visibles, secuencia 2 activa"
    }
  ],
  "news.multiple-sequences.step2.description": [
    {
      "type": 0,
      "value": "Haz clic en cualquier pestaña para cambiar de secuencia activa. Cada secuencia tiene su propio contenido independiente. Busca nuevas palabras para rellenar la secuencia 2."
    }
  ],
  "news.multiple-sequences.step3.alt": [
    {
      "type": 0,
      "value": "Vista de las dos secuencias con tamaño aumentado globalmente"
    }
  ],
  "news.multiple-sequences.step3.description": [
    {
      "type": 0,
      "value": "En la Vista, el interruptor \"Aplicar a todas\" permite ajustar el tamaño y el espacio de todas las secuencias a la vez. Mueve el control de tamaño para ver el cambio aplicado globalmente."
    }
  ],
  "news.multiple-sequences.step4.alt": [
    {
      "type": 0,
      "value": "Vista con la secuencia 2 ajustada individualmente a tamaño diferente"
    }
  ],
  "news.multiple-sequences.step4.description": [
    {
      "type": 0,
      "value": "Desactiva \"Aplicar a todas\" para configurar cada secuencia de forma independiente. Despliega el acordeón de la secuencia que quieres ajustar y modifica su tamaño o espaciado sin afectar a las demás."
    }
  ],
  "news.multiple-sequences.summary": [
    {
      "type": 0,
      "value": "Ahora puedes crear y gestionar varias secuencias a la vez con pestañas."
    }
  ],
  "news.multiple-sequences.title": [
    {
      "type": 0,
      "value": "Múltiples secuencias"
    }
  ],
  "news.nextArticle": [
    {
      "type": 0,
      "value": "Artículo siguiente"
    }
  ],
  "news.number-font.content": [
    {
      "type": 0,
      "value": "Ahora puedes configurar de forma independiente la tipografía de los números que se añaden a los pictogramas cuando activas la numeración. Desde el diálogo de Configuración por defecto, activando el switch de Numeración, aparecerá una nueva sección para escoger la familia tipográfica, el tamaño y el color de los números, de manera independiente a la tipografía del texto de los pictogramas."
    }
  ],
  "news.number-font.step1.alt": [
    {
      "type": 0,
      "value": "Panel de configuración por defecto con el switch de Numeración desactivado"
    }
  ],
  "news.number-font.step1.description": [
    {
      "type": 0,
      "value": "Abre el diálogo de Configuración por defecto desde el menú principal (haz clic en el logo). Verás un switch para activar la Numeración de los pictogramas."
    }
  ],
  "news.number-font.step2.alt": [
    {
      "type": 0,
      "value": "Switch de Numeración activado en el panel de configuración"
    }
  ],
  "news.number-font.step2.description": [
    {
      "type": 0,
      "value": "Activa el switch de Numeración. Cada pictograma mostrará su número de orden en la posición opuesta al texto."
    }
  ],
  "news.number-font.step3.alt": [
    {
      "type": 0,
      "value": "Nueva sección de configuración de la fuente de los números, con selector de familia, tamaño y color"
    }
  ],
  "news.number-font.step3.description": [
    {
      "type": 0,
      "value": "Una vez activada la numeración, aparece una nueva sección para configurar la tipografía de los números: familia, tamaño y color, de forma independiente a la fuente del texto de los pictogramas."
    }
  ],
  "news.number-font.summary": [
    {
      "type": 0,
      "value": "Elige una tipografía propia para los números que aparecen en los pictogramas."
    }
  ],
  "news.number-font.title": [
    {
      "type": 0,
      "value": "Fuente personalizada para los números"
    }
  ],
  "news.prevArticle": [
    {
      "type": 0,
      "value": "Artículo anterior"
    }
  ],
  "news.print-preview.content": [
    {
      "type": 0,
      "value": "La vista previa te muestra exactamente cómo quedará la página impresa. Puedes controlar el tamaño de los pictogramas, el espacio entre filas y columnas, y la alineación. ¡Todo se ve en tiempo real!"
    }
  ],
  "news.print-preview.img1.alt": [
    {
      "type": 0,
      "value": "Vista previa de la página"
    }
  ],
  "news.print-preview.img2.alt": [
    {
      "type": 0,
      "value": "Controles de tamaño y espacio"
    }
  ],
  "news.print-preview.summary": [
    {
      "type": 0,
      "value": "Previsualiza exactamente cómo quedará tu página antes de imprimir."
    }
  ],
  "news.print-preview.title": [
    {
      "type": 0,
      "value": "Vista previa de impresión"
    }
  ],
  "news.save-improvements.content": [
    {
      "type": 0,
      "value": "Ahora el archivo .saac guarda las imágenes personalizadas que has subido, directamente en el archivo para no perderlas. Además, la configuración de visualización de cada secuencia —tamaño de los pictogramas, espaciado y alineación— también se guarda y recupera exactamente como la dejaste."
    }
  ],
  "news.save-improvements.step1.alt": [
    {
      "type": 0,
