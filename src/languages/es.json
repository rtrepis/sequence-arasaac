  "news.sequence-settings.content": [
    {
      "type": 0,
      "value": "Ahora puedes personalizar cada secuencia de manera independiente. Cambia la alineación de los pictogramas (izquierda, centro o derecha), configura la tipografía y el color de los números de forma independiente al texto, y descubre más opciones de formato para adaptar las secuencias a tus necesidades."
    }
  ],
  "news.sequence-settings.img1.alt": [
    {
      "type": 0,
      "value": "Opciones de alineación"
    }
  ],
