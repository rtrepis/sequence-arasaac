  "news.multiple-sequences.content": [
    {
      "type": 0,
      "value": "Crea tantes seqüències com necessitis! Utilitza les pestanyes per afegir noves seqüències o eliminar les que ja no necessites. Cada seqüència és independent i pots canviar entre elles fàcilment."
    }
  ],
  "news.multiple-sequences.img1.alt": [
    {
      "type": 0,
      "value": "Pestanyes de seqüència"
    }
  ],
  "news.multiple-sequences.img2.alt": [
    {
      "type": 0,
      "value": "Afegir i eliminar seqüències"
    }
  ],
  "news.multiple-sequences.step1.alt": [
    {
      "type": 0,
      "value": "Seqüència 1 amb pictogrames i botó per afegir nova seqüència"
    }
  ],
  "news.multiple-sequences.step1.description": [
    {
      "type": 0,
      "value": "A la pàgina d'edició, busca paraules al cercador (separades per comes) i els pictogrames apareixeran automàticament a la seqüència activa. Fes clic al botó + per crear una nova seqüència."
    }
  ],
  "news.multiple-sequences.step2.alt": [
    {
      "type": 0,
      "value": "Dues pestanyes de seqüència visibles, seqüència 2 activa"
    }
  ],
  "news.multiple-sequences.step2.description": [
    {
      "type": 0,
      "value": "Fes clic a qualsevol pestanya per canviar de seqüència activa. Cada seqüència té el seu propi contingut independent. Busca noves paraules per omplir la seqüència 2."
    }
  ],
  "news.multiple-sequences.step3.alt": [
    {
      "type": 0,
      "value": "Vista de les dues seqüències amb mida augmentada globalment"
    }
  ],
  "news.multiple-sequences.step3.description": [
    {
      "type": 0,
      "value": "A la Vista, el commutador \"Aplicar a totes\" permet ajustar la mida i l'espai de totes les seqüències alhora. Mou el control de mida per veure el canvi aplicat globalment."
    }
  ],
  "news.multiple-sequences.step4.alt": [
    {
      "type": 0,
      "value": "Vista amb la seqüència 2 ajustada individualment a mida diferent"
    }
  ],
  "news.multiple-sequences.step4.description": [
    {
      "type": 0,
      "value": "Desactiva \"Aplicar a totes\" per configurar cada seqüència de manera independent. Expandeix l'acordió de la seqüència que vols ajustar i modifica la seva mida o espaiament sense afectar les altres."
    }
  ],
  "news.multiple-sequences.summary": [
    {
      "type": 0,
      "value": "Ara pots crear i gestionar diverses seqüències alhora amb pestanyes."
    }
  ],
  "news.multiple-sequences.title": [
    {
      "type": 0,
      "value": "Múltiples seqüències"
    }
  ],
  "news.print-preview.content": [
    {
      "type": 0,
      "value": "La vista prèvia et mostra exactament com quedarà la pàgina impresa. Pots controlar la mida dels pictogrames, l'espai entre files i columnes, i l'alineació. Tot es veu en temps real!"
    }
  ],
  "news.print-preview.img1.alt": [
    {
      "type": 0,
      "value": "Vista prèvia de la pàgina"
    }
  ],
  "news.print-preview.img2.alt": [
    {
      "type": 0,
      "value": "Controls de mida i espai"
    }
  ],
  "news.print-preview.summary": [
    {
      "type": 0,
      "value": "Previsualitza exactament com quedarà la teva pàgina abans d'imprimir."
    }
  ],
  "news.print-preview.title": [
    {
      "type": 0,
      "value": "Vista prèvia d'impressió"
    }
  ],
  "news.save-load.content": [
    {
      "type": 0,
      "value": "Trobaràs les opcions de guardar i carregar al menú del logo de SequenciAAC. Quan guardes, es descarrega un fitxer amb totes les seqüències i les imatges dels pictogrames incloses. Així pots recuperar el teu treball en qualsevol moment!"
    }
  ],
  "news.save-load.img1.alt": [
    {
      "type": 0,
      "value": "Menú amb opció de guardar"
    }
  ],
  "news.save-load.img2.alt": [
    {
      "type": 0,
      "value": "Carregar fitxer guardat"
    }
  ],
  "news.save-load.summary": [
    {
      "type": 0,
      "value": "Descarrega les teves seqüències amb les imatges i carrega-les quan vulguis."
    }
  ],
  "news.save-load.title": [
