  "news.multiple-sequences.title": {
    "defaultMessage": "Multiple sequences",
    "description": "Títol notícia múltiples seqüències"
  },
  "news.multiple-sequences.summary": {
    "defaultMessage": "You can now create and manage multiple sequences at once with tabs.",
    "description": "Resum notícia múltiples seqüències"
  },
  "news.multiple-sequences.content": {
    "defaultMessage": "Create as many sequences as you need! Use tabs to add new sequences or remove the ones you no longer need. Each sequence is independent and you can switch between them easily.",
    "description": "Contingut notícia múltiples seqüències"
  },
  "news.multiple-sequences.img1.alt": {
    "defaultMessage": "Sequence tabs",
    "description": "Alt imatge 1 múltiples seqüències"
  },
