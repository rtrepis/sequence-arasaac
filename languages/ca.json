  },
  "news.print-preview.img2.alt": {
    "defaultMessage": "Controls de mida i espai",
    "description": "Alt imatge 2 vista prèvia"
  },
  "news.sequence-settings.title": {
    "defaultMessage": "Noves configuracions per seqüència",
    "description": "Títol notícia configuracions"
  },
  "news.sequence-settings.summary": {
    "defaultMessage": "Personalitza cada seqüència amb alineació, tipografia dels números i més opcions.",
    "description": "Resum notícia configuracions"
  },
  "news.sequence-settings.content": {
    "defaultMessage": "Ara pots personalitzar cada seqüència de manera independent. Canvia l'alineació dels pictogrames (esquerra, centre o dreta), configura la tipografia i el color dels números de forma independent al text, i descobreix més opcions de format per adaptar les seqüències a les teves necessitats.",
    "description": "Contingut notícia configuracions"
  },
