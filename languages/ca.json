  "news.multiple-sequences.title": {
    "defaultMessage": "Múltiples seqüències",
    "description": "Títol notícia múltiples seqüències"
  },
  "news.multiple-sequences.summary": {
    "defaultMessage": "Ara pots crear i gestionar diverses seqüències alhora amb pestanyes.",
    "description": "Resum notícia múltiples seqüències"
  },
  "news.multiple-sequences.content": {
    "defaultMessage": "Crea tantes seqüències com necessitis! Utilitza les pestanyes per afegir noves seqüències o eliminar les que ja no necessites. Cada seqüència és independent i pots canviar entre elles fàcilment.",
    "description": "Contingut notícia múltiples seqüències"
  },
  "news.multiple-sequences.img1.alt": {
    "defaultMessage": "Pestanyes de seqüència",
    "description": "Alt imatge 1 múltiples seqüències"
  },
  "news.multiple-sequences.img2.alt": {
    "defaultMessage": "Afegir i eliminar seqüències",
    "description": "Alt imatge 2 múltiples seqüències"
  },
  "news.multiple-sequences.step1.alt": {
    "defaultMessage": "Seqüència 1 amb pictogrames i botó per afegir nova seqüència",
    "description": "Alt imatge pas 1 múltiples seqüències"
  },
  "news.multiple-sequences.step1.description": {
    "defaultMessage": "A la pàgina d'edició, busca paraules al cercador (separades per comes) i els pictogrames apareixeran automàticament a la seqüència activa. Fes clic al botó + per crear una nova seqüència.",
    "description": "Descripció pas 1 múltiples seqüències"
  },
  "news.multiple-sequences.step2.alt": {
    "defaultMessage": "Dues pestanyes de seqüència visibles, seqüència 2 activa",
    "description": "Alt imatge pas 2 múltiples seqüències"
  },
  "news.multiple-sequences.step2.description": {
    "defaultMessage": "Fes clic a qualsevol pestanya per canviar de seqüència activa. Cada seqüència té el seu propi contingut independent. Busca noves paraules per omplir la seqüència 2.",
    "description": "Descripció pas 2 múltiples seqüències"
  },
  "news.multiple-sequences.step3.alt": {
    "defaultMessage": "Vista de les dues seqüències amb mida augmentada globalment",
    "description": "Alt imatge pas 3 múltiples seqüències"
  },
  "news.multiple-sequences.step3.description": {
    "defaultMessage": "A la Vista, el commutador \"Aplicar a totes\" permet ajustar la mida i l'espai de totes les seqüències alhora. Mou el control de mida per veure el canvi aplicat globalment.",
    "description": "Descripció pas 3 múltiples seqüències"
  },
  "news.multiple-sequences.step4.alt": {
    "defaultMessage": "Vista amb la seqüència 2 ajustada individualment a mida diferent",
    "description": "Alt imatge pas 4 múltiples seqüències"
  },
  "news.multiple-sequences.step4.description": {
    "defaultMessage": "Desactiva \"Aplicar a totes\" per configurar cada seqüència de manera independent. Expandeix l'acordió de la seqüència que vols ajustar i modifica la seva mida o espaiament sense afectar les altres.",
    "description": "Descripció pas 4 múltiples seqüències"
  },
  "news.print-preview.title": {
    "defaultMessage": "Vista prèvia d'impressió",
    "description": "Títol notícia vista prèvia"
  },
  "news.print-preview.summary": {
    "defaultMessage": "Previsualitza exactament com quedarà la teva pàgina abans d'imprimir.",
    "description": "Resum notícia vista prèvia"
  },
  "news.print-preview.content": {
    "defaultMessage": "La vista prèvia et mostra exactament com quedarà la pàgina impresa. Pots controlar la mida dels pictogrames, l'espai entre files i columnes, i l'alineació. Tot es veu en temps real!",
    "description": "Contingut notícia vista prèvia"
  },
  "news.print-preview.img1.alt": {
