  "news.save-load.summary": {
    "defaultMessage": "Descarrega les teves seqüències amb les imatges i carrega-les quan vulguis.",
    "description": "Resum notícia guardar i carregar"
  },
  "news.save-load.content": {
    "defaultMessage": "Trobaràs les opcions de guardar i carregar al menú del logo de SequenciAAC. Quan guardes, es descarrega un fitxer amb totes les seqüències i les imatges dels pictogrames incloses. Així pots recuperar el teu treball en qualsevol moment!",
    "description": "Contingut notícia guardar i carregar"
  },
