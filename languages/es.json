    "defaultMessage": "Nuevas configuraciones por secuencia",
    "description": "Títol notícia configuracions"
  },
  "news.sequence-settings.summary": {
    "defaultMessage": "Personaliza cada secuencia con alineación, tipografía de los números y más opciones.",
    "description": "Resum notícia configuracions"
  },
  "news.sequence-settings.content": {
    "defaultMessage": "Ahora puedes personalizar cada secuencia de manera independiente. Cambia la alineación de los pictogramas (izquierda, centro o derecha), configura la tipografía y el color de los números de forma independiente al texto, y descubre más opciones de formato para adaptar las secuencias a tus necesidades.",
    "description": "Contingut notícia configuracions"
  },
