  "news.multiple-sequences.title": {
    "defaultMessage": "Múltiples secuencias",
    "description": "Títol notícia múltiples seqüències"
  },
  "news.multiple-sequences.summary": {
    "defaultMessage": "Ahora puedes crear y gestionar varias secuencias a la vez con pestañas.",
    "description": "Resum notícia múltiples seqüències"
  },
  "news.multiple-sequences.content": {
    "defaultMessage": "¡Crea tantas secuencias como necesites! Utiliza las pestañas para añadir nuevas secuencias o eliminar las que ya no necesitas. Cada secuencia es independiente y puedes cambiar entre ellas fácilmente.",
    "description": "Contingut notícia múltiples seqüències"
  },
  "news.multiple-sequences.img1.alt": {
    "defaultMessage": "Pestañas de secuencia",
    "description": "Alt imatge 1 múltiples seqüències"
  },
  "news.multiple-sequences.img2.alt": {
    "defaultMessage": "Añadir y eliminar secuencias",
    "description": "Alt imatge 2 múltiples seqüències"
  },
  "news.multiple-sequences.step1.alt": {
    "defaultMessage": "Secuencia 1 con pictogramas y botón para añadir nueva secuencia",
    "description": "Alt imatge pas 1 múltiples seqüències"
  },
  "news.multiple-sequences.step1.description": {
    "defaultMessage": "En la página de edición, busca palabras en el buscador (separadas por comas) y los pictogramas aparecerán automáticamente en la secuencia activa. Haz clic en el botón + para crear una nueva secuencia.",
    "description": "Descripció pas 1 múltiples seqüències"
  },
  "news.multiple-sequences.step2.alt": {
    "defaultMessage": "Dos pestañas de secuencia visibles, secuencia 2 activa",
    "description": "Alt imatge pas 2 múltiples seqüències"
  },
  "news.multiple-sequences.step2.description": {
    "defaultMessage": "Haz clic en cualquier pestaña para cambiar de secuencia activa. Cada secuencia tiene su propio contenido independiente. Busca nuevas palabras para rellenar la secuencia 2.",
    "description": "Descripció pas 2 múltiples seqüències"
  },
  "news.multiple-sequences.step3.alt": {
    "defaultMessage": "Vista de las dos secuencias con tamaño aumentado globalmente",
    "description": "Alt imatge pas 3 múltiples seqüències"
  },
  "news.multiple-sequences.step3.description": {
    "defaultMessage": "En la Vista, el interruptor \"Aplicar a todas\" permite ajustar el tamaño y el espacio de todas las secuencias a la vez. Mueve el control de tamaño para ver el cambio aplicado globalmente.",
    "description": "Descripció pas 3 múltiples seqüències"
  },
  "news.multiple-sequences.step4.alt": {
    "defaultMessage": "Vista con la secuencia 2 ajustada individualmente a tamaño diferente",
    "description": "Alt imatge pas 4 múltiples seqüències"
  },
  "news.multiple-sequences.step4.description": {
    "defaultMessage": "Desactiva \"Aplicar a todas\" para configurar cada secuencia de forma independiente. Despliega el acordeón de la secuencia que quieres ajustar y modifica su tamaño o espaciado sin afectar a las demás.",
    "description": "Descripció pas 4 múltiples seqüències"
  },
  "news.print-preview.title": {
    "defaultMessage": "Vista previa de impresión",
    "description": "Títol notícia vista prèvia"
  },
  "news.print-preview.summary": {
    "defaultMessage": "Previsualiza exactamente cómo quedará tu página antes de imprimir.",
