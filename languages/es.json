  "news.number-font.summary": {
    "defaultMessage": "Elige una tipografía propia para los números que aparecen en los pictogramas.",
    "description": "Resum notícia font dels números"
  },
  "news.number-font.content": {
    "defaultMessage": "Ahora puedes configurar de forma independiente la tipografía de los números que se añaden a los pictogramas cuando activas la numeración. Desde el diálogo de Configuración por defecto, activando el switch de Numeración, aparecerá una nueva sección para escoger la familia tipográfica, el tamaño y el color de los números, de manera independiente a la tipografía del texto de los pictogramas.",
    "description": "Contingut notícia font dels números"
  },
