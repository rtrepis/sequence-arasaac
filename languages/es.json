  "news.view-improvements.title": {
    "defaultMessage": "Mejoras en la previsualización",
    "description": "Títol notícia millores vista"
  },
  "news.view-improvements.summary": {
    "defaultMessage": "Vista previa fiel a la impresión, nuevos controles de alineación y dirección.",
    "description": "Resum notícia millores vista"
  },
  "news.view-improvements.content": {
    "defaultMessage": "Se han corregido errores que hacían que la vista previa no coincidiera exactamente con el resultado impreso. Además, se han añadido nuevos controles de alineación y dirección para cada secuencia, y ahora cuando guardas una secuencia la configuración de visualización también se guarda automáticamente.",
    "description": "Contingut notícia millores vista"
  },
  "news.view-improvements.step1.alt": {
    "defaultMessage": "Vista previa de la secuencia mostrando la correspondencia exacta con la impresión",
    "description": "Alt pas 1 millores vista"
  },
  "news.view-improvements.step1.description": {
    "defaultMessage": "La previsualización ahora corresponde exactamente al resultado impreso. Un cálculo de escala preciso tiene en cuenta el formato de página (A4, A3) y la resolución de pantalla para mostrar fielmente lo que se imprimirá.",
    "description": "Descripció pas 1 millores vista"
  },
  "news.view-improvements.step2.alt": {
    "defaultMessage": "Controles de alineación y dirección de las secuencias",
    "description": "Alt pas 2 millores vista"
  },
  "news.view-improvements.step2.description": {
    "defaultMessage": "Nuevos controles para personalizar cada secuencia: elige la alineación (izquierda, centro, derecha) y la dirección (horizontal o vertical) para adaptar la presentación a tus necesidades.",
    "description": "Descripció pas 2 millores vista"
  },
  "news.view-improvements.step3.alt": {
    "defaultMessage": "Botón de guardar la secuencia con configuración de visualización incluida",
    "description": "Alt pas 3 millores vista"
  },
  "news.view-improvements.step3.description": {
    "defaultMessage": "Cuando guardas la secuencia con el botón de descarga, la configuración de visualización (tamaños, espacios, alineación y dirección) se incluye automáticamente en el archivo, de manera que cuando la vuelves a cargar todo quedará tal como lo habías dejado.",
    "description": "Descripció pas 3 millores vista"
  },
  "news.save-improvements.title": {
    "defaultMessage": "Mejoras al guardado",
    "description": "Títol notícia millores guardat"
  },
  "news.save-improvements.summary": {
    "defaultMessage": "El archivo guardado ahora incluye imágenes personalizadas y la configuración de tamaño y espaciado de cada secuencia.",
    "description": "Resum notícia millores guardat"
  },
  "news.save-improvements.content": {
    "defaultMessage": "Ahora el archivo .saac guarda las imágenes personalizadas que has subido, directamente en el archivo para no perderlas. Además, la configuración de visualización de cada secuencia —tamaño de los pictogramas, espaciado y alineación— también se guarda y recupera exactamente como la dejaste.",
    "description": "Contingut notícia millores guardat"
  },
  "news.save-improvements.step1.alt": {
