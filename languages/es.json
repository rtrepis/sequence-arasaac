    "description": "Descripció pas 1 millores guardat"
  },
  "news.save-improvements.step2.alt": {
    "defaultMessage": "Diálogo de guardar con las opciones de secuencias y configuración",
    "description": "Alt pas 2 millores guardat"
  },
  "news.save-improvements.step2.description": {
